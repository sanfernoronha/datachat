# Copy this file to .env and fill in your values.
# Never commit .env to source control.
#
# Quick start:
#   cp .env.example .env
#   # Fill in at least one API key below
#   docker compose up

# ─── LLM Provider ────────────────────────────────────────────────────────────
# Which provider to use: anthropic | openai | google  (default: anthropic)
MODEL_PROVIDER=anthropic

# Override the specific model name (optional — each provider has a sensible default)
# Defaults: anthropic=claude-sonnet-4-6  openai=gpt-4o  google=gemini-2.0-flash
# MODEL_NAME=

# Provider API keys — only the key for the active MODEL_PROVIDER is required
ANTHROPIC_API_KEY="sk-ant-your-key-here"
# OPENAI_API_KEY="sk-your-key-here"
# GOOGLE_API_KEY="your-key-here"

# ─── Advanced (usually no need to change) ─────────────────────────────────────
# These are set automatically by docker-compose.yml.
# Only uncomment if running outside Docker.
# DATABASE_URL="postgresql://postgres:password@localhost:5432/datachat?schema=public"
# SANDBOX_URL="http://localhost:8888"
# MAX_UPLOAD_SIZE_BYTES=104857600
